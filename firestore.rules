
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Check if the user is a member of a specific chat by checking the chatMemberships collection
    // This assumes chatMemberships documents have an ID of `{chatId}_{userId}`
    function isChatMember(chatId) {
      return isSignedIn() && exists(/databases/$(database)/documents/chatMemberships/$(chatId + '_' + request.auth.uid));
    }

    function getChatRole(chatId) {
      let membershipDoc = get(/databases/$(database)/documents/chatMemberships/$(chatId + '_' + request.auth.uid));
      return membershipDoc.data.role;
    }
    
    function isChatAdmin(chatId) {
      return isChatMember(chatId) && getChatRole(chatId) == 'admin';
    }
    
    // --- Collections ---

    // User Profiles
    match /users/{userId} {
      allow read: if true;
      allow create, update: if isOwner(userId);
    }

    // Chats and Messages
    match /chats/{chatId} {
      allow read, update: if isChatMember(chatId);
      allow create: if isSignedIn(); // Any signed-in user can create a chat

      match /messages/{messageId} {
        allow read, create: if isChatMember(chatId);
        allow update, delete: if isChatMember(chatId) && resource.data.senderId == request.auth.uid;
      }
    }

    // Chat Memberships (Document ID: {chatId}_{userId})
    match /chatMemberships/{membershipId} {
        // A user can read their own membership doc. An admin of the chat can read any membership.
        allow read: if (isSignedIn() && request.auth.uid == split(membershipId,'_')[1]) || isChatAdmin(split(membershipId,'_')[0]);
        // A chat admin can add/remove users. A user can add/remove themselves.
        allow write: if isChatAdmin(split(membershipId,'_')[0]) || (isSignedIn() && request.auth.uid == split(membershipId,'_')[1]);
    }
    
    // Reactions
    match /reactions/{reactionId} {
        // Only members of the chat can read reactions in that chat
        allow list, get: if isChatMember(resource.data.chatId);
        // User must be a member to create a reaction and can only create reactions for themselves
        allow create: if isChatMember(request.resource.data.chatId) && request.auth.uid == request.resource.data.userId;
        // Only the user who created the reaction can delete it
        allow delete: if isOwner(resource.data.userId);
    }
  }
}
