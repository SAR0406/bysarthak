
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'sarthak040624@gmail.com';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collections ---

    // User Profiles
    match /users/{userId} {
      allow read: if true;
      allow create, update: if isOwner(userId);
    }

    // Conversations (as shown in screenshot)
    match /conversations/{email} {
      // Admin can do everything. Visitors can access their own thread.
      allow read, write: if isAdmin() || (isSignedIn() && request.auth.token.email == email);
    }
  }
}
