
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Represents a user's profile information.",
      "type": "object",
      "properties": {
        "username": {
          "type": "string",
          "description": "The user's unique username."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the user profile was created."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "profilePictureUrl": {
          "type": "string",
          "format": "uri",
          "description": "URL for the user's profile picture."
        },
        "lastOnlineAt": {
          "type": "string",
          "format": "date-time",
          "description": "The last time the user was seen online."
        }
      },
      "required": ["username", "email", "createdAt", "displayName"]
    },
    "ConversationMessage": {
      "title": "Conversation Message",
      "description": "A single message within a conversation array.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "text": { "type": "string" },
        "imageUrl": { "type": "string", "format": "uri" },
        "sentAt": { "type": "string", "format": "date-time" },
        "sentBy": { "type": "string", "enum": ["admin", "visitor"] },
        "senderName": { "type": "string" },
        "senderEmail": { "type": "string" },
        "readBy": { 
          "type": "object",
          "description": "Map of user email to read timestamp."
        },
        "reactions": {
          "type": "object",
          "description": "Map of user email to emoji string."
        }
      }
    },
    "Conversation": {
      "title": "Conversation",
      "description": "A support or contact conversation thread.",
      "type": "object",
      "properties": {
        "groupId": { "type": "string" },
        "senderName": { "type": "string" },
        "senderEmail": { "type": "string" },
        "lastMessageAt": { "type": "string", "format": "date-time" },
        "messages": {
          "type": "array",
          "items": { "$ref": "#/backend/entities/ConversationMessage" }
        },
        "typing": { "type": "object" },
        "presence": { "type": "object" }
      }
    }
  },
  "auth": {
    "providers": [
      "password",
      "google.com"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "schema": {
            "$ref": "#/backend/entities/UserProfile"
          },
          "description": "Stores user profiles."
        }
      },
      {
        "path": "/conversations/{email}",
        "definition": {
          "schema": {
            "$ref": "#/backend/entities/Conversation"
          },
          "description": "Stores support conversations, keyed by visitor email."
        }
      }
    ]
  }
}
